model CustomerDebt {
  id          String        @id @default(cuid())
  customerId  String
  customer    Customer      @relation(fields: [customerId], references: [id])
  orderId     String?
  order       Order?        @relation(fields: [orderId], references: [id])
  description String
  totalAmount Float
  paidAmount  Float         @default(0)
  dueDate     DateTime?
  status      String        @default("BEKLIYOR")
  createdAt   DateTime      @default(now())
  payments    DebtPayment[]
}

model DebtPayment {
  id      String       @id @default(cuid())
  debtId  String
  debt    CustomerDebt @relation(fields: [debtId], references: [id])
  amount  Float
  note    String?
  paidAt  DateTime     @default(now())
}

model SupplierDebt {
  id           String           @id @default(cuid())
  supplierName String
  description  String
  totalAmount  Float
  paidAmount   Float            @default(0)
  dueDate      DateTime?
  status       String           @default("BEKLIYOR")
  createdAt    DateTime         @default(now())
  payments     SupplierPayment[]
}

model SupplierPayment {
  id     String       @id @default(cuid())
  debtId String
  debt   SupplierDebt @relation(fields: [debtId], references: [id])
  amount Float
  note   String?
  paidAt DateTime     @default(now())
}
