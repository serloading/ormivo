generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Brand {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  logo      String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Product {
  id           String     @id @default(cuid())
  productNo    String?    @unique
  name         String
  slug         String     @unique
  description  String?
  price        Decimal    @db.Decimal(10, 2)
  comparePrice Decimal?   @db.Decimal(10, 2)
  costPrice    Decimal?   @db.Decimal(10, 2)
  costPriceUsd Decimal?   @db.Decimal(10, 2)
  images       String[]
  categoryId        String?
  category          Category?  @relation(fields: [categoryId], references: [id])
  extraCategoryIds  String[]
  brandId      String?
  brand        Brand?     @relation(fields: [brandId], references: [id])
  scentNotes         String?
  stock              Int        @default(0)
  isActive           Boolean    @default(true)
  isOzelKoleksiyon   Boolean    @default(false)
  isBestSeller       Boolean    @default(false)
  deletedAt          DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  cartItems    CartItem[]
  favorites    Favorite[]
}

model Customer {
  id         String          @id @default(cuid())
  customerNo String?         @unique
  name       String
  phone      String?
  email      String?
  city       String?
  address    String?
  note       String?
  segment    String?
  tags       String[]
  orders     Order[]
  siteOrders SiteOrder[]
  cargos     CargoTracking[]
  debts      CustomerDebt[]
  notes      CustomerNote[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  content    String
  createdBy  String
  createdAt  DateTime @default(now())
}

model Order {
  id         String        @id @default(cuid())
  orderNo    String        @unique
  customerId String?
  customer   Customer?     @relation(fields: [customerId], references: [id])
  items      Json
  total          Decimal       @db.Decimal(10, 2)
  shippingFee    Decimal?      @db.Decimal(10, 2)
  status         OrderStatus   @default(PENDING)
  paymentStatus  String        @default("PENDING")
  deliveryMethod String        @default("PICKUP")
  note           String?
  cargo       CargoTracking?
  customerDebts CustomerDebt[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model CargoTracking {
  id         String      @id @default(cuid())
  orderId    String      @unique
  order      Order       @relation(fields: [orderId], references: [id])
  customerId String
  customer   Customer    @relation(fields: [customerId], references: [id])
  company    String?
  trackingNo String?
  status     CargoStatus @default(PREPARING)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

enum CargoStatus {
  PREPARING
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RETURNED
}

model Finance {
  id           String      @id @default(cuid())
  type         FinanceType
  amount       Decimal     @db.Decimal(10, 2)
  description  String
  category     String?
  date         DateTime    @default(now())
  createdAt    DateTime    @default(now())
  siteOrderId  String?
}

enum FinanceType {
  INCOME
  EXPENSE
}

// â”€â”€ Site KullanÄ±cÄ±larÄ± â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model SiteUser {
  id                 String      @id @default(cuid())
  phone              String      @unique
  name               String?
  passwordHash       String
  mustChangePassword Boolean     @default(false)
  segment            String?     // BRONZE | SILVER | GOLD | null
  createdAt          DateTime    @default(now())
  cart               Cart?
  addresses          Address[]
  siteOrders         SiteOrder[]
  favorites          Favorite[]
  favoriteLists      FavoriteList[]
}

model Address {
  id            String      @id @default(cuid())
  userId        String
  user          SiteUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipientName String
  phone         String
  addressLine   String
  city          String
  district      String?
  isDefault     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  siteOrders    SiteOrder[]
}

model SiteOrder {
  id             String      @id @default(cuid())
  orderNo        String      @unique @default(cuid())
  status         OrderStatus @default(PENDING)
  userId         String?
  user           SiteUser?   @relation(fields: [userId], references: [id])
  addressId      String?
  address        Address?    @relation(fields: [addressId], references: [id])
  recipientName  String?
  recipientPhone String?
  addressLine    String?
  city           String?
  district       String?
  items          Json
  total          Decimal     @db.Decimal(10, 2)
  customerId     String?
  customer       Customer?   @relation(fields: [customerId], references: [id])
  trackingNo     String?
  cargoCompany   String?
  note           String?
  paymentStatus  String      @default("PENDING")
  deliveryMethod String      @default("CARGO")
  discount       Decimal     @default(0) @db.Decimal(10, 2)
  couponCode     String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      SiteUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  updatedAt DateTime   @updatedAt @default(now())
}

model CartItem {
  id           String   @id @default(cuid())
  cartId       String
  cart         Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  quantity     Int      @default(1)
  customPrice  Decimal? @db.Decimal(10, 2)
  addedAt      DateTime @default(now())

  @@unique([cartId, productId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      SiteUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model FavoriteList {
  id         String   @id @default(cuid())
  userId     String
  user       SiteUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  productIds String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  discountType  String    @default("PERCENT")
  discountValue Decimal   @db.Decimal(10, 2)
  minOrderTotal Decimal?  @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int       @default(0)
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  adminEmail String
  action     String
  entity     String
  entityId   String
  detail     Json?
  createdAt  DateTime @default(now())
}

// â”€â”€ BorÃ§ / Alacak Takibi â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

model CustomerDebt {
  id          String        @id @default(cuid())
  customerId  String
  customer    Customer      @relation(fields: [customerId], references: [id])
  orderId     String?
  order       Order?        @relation(fields: [orderId], references: [id])
  description String
  totalAmount Float
  paidAmount  Float         @default(0)
  dueDate     DateTime?
  status      String        @default("BEKLIYOR")
  createdAt   DateTime      @default(now())
  payments    DebtPayment[]
}

model DebtPayment {
  id      String       @id @default(cuid())
  debtId  String
  debt    CustomerDebt @relation(fields: [debtId], references: [id])
  amount  Float
  note    String?
  paidAt  DateTime     @default(now())
}

model SupplierDebt {
  id           String           @id @default(cuid())
  supplierName String
  description  String
  totalAmount  Float
  paidAmount   Float            @default(0)
  dueDate      DateTime?
  status       String           @default("BEKLIYOR")
  createdAt    DateTime         @default(now())
  payments     SupplierPayment[]
}

model SupplierPayment {
  id     String       @id @default(cuid())
  debtId String
  debt   SupplierDebt @relation(fields: [debtId], references: [id])
  amount Float
  note   String?
  paidAt DateTime     @default(now())
}

// ── Depo Sipariş Yönetimi ────────────────────────────────────

model DepoSiparis {
  id           String   @id @default(cuid())
  title        String   @default("Haftalık Sipariş")
  orderDate    DateTime @default(now())
  items        Json     // [{ productId?, name, qty, unitPrice }]
  total        Float    @default(0)
  paidAmount   Float    @default(0)
  supplierName String?
  status       String   @default("HAZIRLANIYOR") // HAZIRLANIYOR | ILETILDI
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
