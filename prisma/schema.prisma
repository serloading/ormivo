generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Brand {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  logo      String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Product {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  description  String?
  price        Decimal    @db.Decimal(10, 2)
  comparePrice Decimal?   @db.Decimal(10, 2)
  costPrice    Decimal?   @db.Decimal(10, 2)
  costPriceUsd Decimal?   @db.Decimal(10, 2)
  images       String[]
  categoryId   String?
  category     Category?  @relation(fields: [categoryId], references: [id])
  brandId      String?
  brand        Brand?     @relation(fields: [brandId], references: [id])
  stock              Int        @default(0)
  isActive           Boolean    @default(true)
  isOzelKoleksiyon   Boolean    @default(false)
  deletedAt          DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  cartItems    CartItem[]
}

model Customer {
  id         String          @id @default(cuid())
  name       String
  phone      String?
  email      String?
  city       String?
  address    String?
  note       String?
  segment    String?
  tags       String[]
  orders     Order[]
  siteOrders SiteOrder[]
  cargos     CargoTracking[]
  debts      CustomerDebt[]
  notes      CustomerNote[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  content    String
  createdBy  String
  createdAt  DateTime @default(now())
}

model Order {
  id         String        @id @default(cuid())
  orderNo    String        @unique
  customerId String
  customer   Customer      @relation(fields: [customerId], references: [id])
  items      Json
  total          Decimal       @db.Decimal(10, 2)
  shippingFee    Decimal?      @db.Decimal(10, 2)
  status         OrderStatus   @default(PENDING)
  paymentStatus  String        @default("PENDING")
  deliveryMethod String        @default("PICKUP")
  note           String?
  cargo       CargoTracking?
  customerDebts CustomerDebt[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

model CargoTracking {
  id         String      @id @default(cuid())
  orderId    String      @unique
  order      Order       @relation(fields: [orderId], references: [id])
  customerId String
  customer   Customer    @relation(fields: [customerId], references: [id])
  company    String?
  trackingNo String?
  status     CargoStatus @default(PREPARING)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

enum CargoStatus {
  PREPARING
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RETURNED
}

model Finance {
  id           String      @id @default(cuid())
  type         FinanceType
  amount       Decimal     @db.Decimal(10, 2)
  description  String
  category     String?
  date         DateTime    @default(now())
  createdAt    DateTime    @default(now())
  siteOrderId  String?
}

enum FinanceType {
  INCOME
  EXPENSE
}

